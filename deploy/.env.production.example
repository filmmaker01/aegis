# Production env for the VPS stack. Copy to `deploy/.env` ON THE SERVER, fill it
# in, and `chmod 600` it. Never commit the real file: .gitignore already covers
# `.env` / `.env.*` and gitleaks scans every push.
#
#   cp deploy/.env.production.example deploy/.env && chmod 600 deploy/.env
#
# Generate every secret below with:
#   openssl rand -hex 32

# --- PostgreSQL (consumed by the postgres container) ---------------------------
POSTGRES_USER=planner
POSTGRES_PASSWORD=<openssl rand -hex 32>
POSTGRES_DB=planner

# --- Backend -------------------------------------------------------------------
# Host is the compose service name. It resolves only on the `internal` network,
# which is marked `internal: true` — no route in or out. That isolation is why
# this URL needs no TLS, and why env.ts accepts a bare hostname in production.
# The password must match POSTGRES_PASSWORD (URL-encode any reserved characters).
DATABASE_URL=postgresql://planner:<POSTGRES_PASSWORD>@postgres:5432/planner?schema=public

JWT_SECRET=<openssl rand -hex 32>
# The bot has no browser client; this only needs to be a valid https origin.
CORS_ORIGINS=https://<your-domain>

# --- Telegram ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_WEBHOOK_SECRET=<openssl rand -hex 32>
# Used by `bun run --cwd backend set-webhook` instead of passing --url.
TELEGRAM_WEBHOOK_URL=https://<your-domain>/telegram/webhook

# --- Reminders (defaults are fine) ---------------------------------------------
REMINDER_SWEEP_SECONDS=30
REMINDER_MAX_ATTEMPTS=5
REMINDER_STALLED_AFTER_SECONDS=300

# --- Caddy ---------------------------------------------------------------------
# DNS for DOMAIN must already resolve to this VPS, or the ACME challenge fails.
DOMAIN=<your-domain>
ACME_EMAIL=<you@example.com>

# --- Backup --------------------------------------------------------------------
BACKUP_RETENTION_DAYS=14
BACKUP_MIN_FREE_MB=2048
# Hour of day (UTC, 0-23) for the daily dump.
BACKUP_SCHEDULE_HOUR=3

# --- Offsite backup (optional; leave unset to keep backups local only) ---------
# See deploy/backup/offsite.sh. Configure rclone or any S3-compatible target.
# Put real credentials only on the server, never here.
# OFFSITE_REMOTE=s3remote:planner-backups
# RCLONE_CONFIG_S3REMOTE_TYPE=s3
# RCLONE_CONFIG_S3REMOTE_PROVIDER=Other
# RCLONE_CONFIG_S3REMOTE_ENDPOINT=https://<s3-endpoint>
# RCLONE_CONFIG_S3REMOTE_ACCESS_KEY_ID=<key>
# RCLONE_CONFIG_S3REMOTE_SECRET_ACCESS_KEY=<secret>

# --- Image tag (optional) ------------------------------------------------------
# Tag the built image with the release SHA so `docker image ls` shows what runs.
# IMAGE_TAG=815f8c2
