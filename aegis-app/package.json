{
  "name": "aegis-app",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": [
    "webapp",
    "website",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' --parallel dev",
    "dev:webapp": "bun run --cwd webapp dev",
    "dev:website": "bun run --cwd website dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --filter '*' --sequential build",
    "build:webapp": "bun run --cwd webapp build",
    "build:website": "bun run --cwd website build",
    "build:backend": "bun run --cwd backend build",
    "architecture:check": "bun scripts/architecture-check.mjs",
    "deploy:do:specs": "bun scripts/prepare-do-specs.mjs",
    "typecheck": "bun run --filter '*' --sequential typecheck",
    "typecheck:webapp": "bun run --cwd webapp typecheck",
    "typecheck:website": "bun run --cwd website typecheck",
    "typecheck:backend": "bun run --cwd backend typecheck",
    "test": "bun run test:deploy && bun run test:contracts && bun run test:backend && bun run test:webapp",
    "test:deploy": "bun test scripts/do-cron.test.mjs scripts/prepare-do-specs.test.mjs scripts/repo-env.test.mjs scripts/architecture-check.test.mjs",
    "test:contracts": "bun run --cwd packages/contracts test",
    "test:backend": "bun run --cwd backend test",
    "test:backend:unit": "bun run --cwd backend test:unit",
    "test:backend:integration": "bun run --cwd backend test:integration",
    "test:webapp": "bun run --cwd webapp test",
    "smoke:backend:docker": "bun run --cwd backend smoke:docker",
    "e2e:webapp": "bun run --cwd webapp e2e"
  },
  "description": "Telegram task planner bot (create tasks, pick a reminder time, act on the reminder from inline buttons). Bootstrapped from the Vibe Coding Template (Apache-2.0).",
  "dependencies": {
    "hono": "^4.12.30"
  },
  "comment:trustedDependencies": "embedded-postgres downloads a real PostgreSQL binary in a postinstall; Bun blocks that until the package is trusted. One entry per platform, so `test:pg:local` works on every developer machine, not just the one that added it.",
  "trustedDependencies": [
    "@embedded-postgres/windows-x64",
    "@embedded-postgres/linux-x64",
    "@embedded-postgres/linux-arm64",
    "@embedded-postgres/darwin-x64",
    "@embedded-postgres/darwin-arm64"
  ]
}
