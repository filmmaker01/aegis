# Aegis — environment template. Copy to .env and fill in. NEVER commit .env.
# No real secrets belong in this file.
#
# --- Local PostgreSQL (Docker Compose) ---
# These are LOCAL-ONLY, non-secret dev defaults matching docker-compose.yml and
# docs/LOCAL_DATABASE.md. They must never be reused in any deployed environment.

POSTGRES_PORT=54329
POSTGRES_TEST_PORT=54330

# Application database used by backend/.env in local development.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/web_app_demo?schema=public"

# Test database used by backend integration, Docker smoke, and Playwright E2E.
# Automated runners may override POSTGRES_TEST_PORT with a repository-derived
# port so parallel checkouts do not collide.
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/web_app_demo_test?schema=public"

# --- Aegis / Telegram (placeholders; wiring is deferred to later phases) ---
# Bot token from @BotFather. Secret — keep only in .env, never log it.
# TELEGRAM_BOT_TOKEN=

# Secret echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token webhook header.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TELEGRAM_WEBHOOK_SECRET=

# Max accepted age (seconds) for Mini App initData auth_date. Default 3600.
# TELEGRAM_INITDATA_MAX_AGE_SECONDS=3600

# Archive storage: 'postgres' (default, durable) or 'memory' (temporary, lost on
# restart — only for local dev when Postgres is unavailable).
# ARCHIVE_STORE=postgres

# Media storage: 'local' (disk fallback, no keys) or 's3' (needs SPACES_* below).
# Default: s3 when SPACES_* is configured, else local.
# MEDIA_STORAGE=local
# MEDIA_LOCAL_DIR=./.media
# Max bytes to download from Telegram (Bot API caps ~20MB without a local API server).
# MEDIA_MAX_BYTES=20971520

# Webapp (Mini App) build-time: base URL of the backend API.
# Default http://localhost:3000. Set to the public backend URL in production.
# VITE_API_URL=http://localhost:3000
