# Aegis backend — PRODUCTION env template (Supabase Postgres + Supabase Storage).
# Fill these in the DEPLOY HOST's secret manager (Railway/Fly dashboard), NOT in git.
# Never commit real values. See ../docs/deployment.md.

NODE_ENV=production
PORT=3000

# --- Supabase Postgres ---
# DATABASE_URL = pooled connection (Session pooler, supports prepared statements),
# used by the running app. DIRECT_URL = direct connection (port 5432), used ONLY by
# `prisma migrate deploy`. Both from Supabase → Project Settings → Database → Connection string.
# Keep sslmode=require.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Archive ---
ARCHIVE_STORE=postgres

# --- Telegram ---
TELEGRAM_BOT_TOKEN=<from @BotFather>
# A fresh production secret (different from any dev value):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=<random-32-bytes-hex>
TELEGRAM_INITDATA_MAX_AGE_SECONDS=3600

# --- Media: Supabase Storage (S3-compatible, PRIVATE bucket) ---
MEDIA_STORAGE=s3
MEDIA_MAX_BYTES=20971520
SPACES_REGION=<supabase project region, e.g. eu-central-1>
SPACES_BUCKET=aegis-media
SPACES_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
SPACES_ACCESS_KEY_ID=<Supabase Storage S3 access key>
SPACES_SECRET_ACCESS_KEY=<Supabase Storage S3 secret key>

# --- App ---
JWT_SECRET=<random 32+ char secret>
# Mini App origin(s) allowed by CORS (the deployed webapp URL):
CORS_ORIGINS=https://<your-mini-app-host>

# Optional: error monitoring (leave empty to disable)
SENTRY_DSN=
