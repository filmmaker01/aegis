# Backend PRODUCTION env template.
#
# The deployed stack does NOT use this file: production runs from Docker Compose,
# which builds the backend's environment from `deploy/.env` — see
# ../../deploy/.env.production.example and ../../deploy/README.md.
#
# This template is for running the backend in production mode WITHOUT Compose
# (a bare host, or a hosting platform's secret manager). Never commit real values.

NODE_ENV=production
PORT=3000

# --- Postgres ------------------------------------------------------------------
# The production check in src/env.ts: the database must not be reached over an
# untrusted network in the clear. Either the host is private, or TLS is on.
#
#   private host, no TLS needed — a Docker service name, loopback, or RFC1918:
DATABASE_URL="postgresql://planner:<password>@postgres:5432/planner?schema=public"
#   public host — TLS is mandatory (sslmode=require | verify-ca | verify-full):
# DATABASE_URL="postgresql://user:<password>@db.example.com:5432/planner?sslmode=require"
#
# DIRECT_URL is only needed when a connection pooler fronts Postgres and cannot
# run migrations. There is no pooler in the Compose stack, so leave it unset:
# prisma.config.ts falls back to DATABASE_URL.
# DIRECT_URL=

# --- Tasks ---------------------------------------------------------------------
TASKS_STORE=postgres
# How often the server scans for due reminders, in seconds.
REMINDER_SWEEP_SECONDS=30
# Delivery attempts before a reminder is given up on (state -> failed).
REMINDER_MAX_ATTEMPTS=5
# How long a claimed reminder may sit before the reaper assumes the sending
# process died and returns it to `retry`. Must exceed a real send.
REMINDER_STALLED_AFTER_SECONDS=300

# --- Telegram ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<from @BotFather>
# A fresh production secret (different from any dev value):
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=<random-32-bytes-hex>

# --- App -----------------------------------------------------------------------
JWT_SECRET=<random 32+ char secret>
# Browser origin(s) allowed by CORS (the bot itself has no browser client):
CORS_ORIGINS=https://<your-domain>
COOKIE_SECURE=true

# Optional: error monitoring (leave empty to disable)
SENTRY_DSN=
