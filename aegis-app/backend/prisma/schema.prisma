generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are provided via prisma.config.ts (runtime pooled url + directUrl
  // for migrations). Prisma 7 no longer accepts url/directUrl in the schema file.
}

model User {
  id           String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email        String        @unique
  passwordHash String        @map("password_hash")
  displayName  String?       @map("display_name")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions     AuthSession[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "auth_sessions_user_id_fkey")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

// ─── Task planner ─────────────────────────────────────────────────────────────
// The bot's product tables. Telegram user ids exceed 2^31 -> BigInt.
// ALL instants are stored in UTC; the owner's IANA timezone (bot_users.timezone)
// is applied only when rendering or when resolving a wall-clock slot to an instant.

/// A Telegram user of the bot, plus their preferences. Created on /start.
model BotUser {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  telegramUserId BigInt   @unique @map("telegram_user_id")
  /// IANA name (e.g. "Europe/Moscow"). Null until the user picks one at /start.
  timezone       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tasks  Task[]
  drafts TaskDraft[]

  @@map("bot_users")
}

model Task {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  telegramUserId BigInt    @map("telegram_user_id")
  title          String
  status         String    @default("active") // active | done
  /// When to remind, in UTC. Null = task without a reminder.
  remindAt       DateTime? @map("remind_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // ── Reminder delivery state machine ────────────────────────────────────────
  // pending -> processing -> sent
  //                       -> retry -> processing -> …
  //                       -> failed (permanent, or attempts exhausted)
  // A crashed sweep leaves a row in `processing`; the stalled-claim reaper moves
  // it back to `retry` after REMINDER_STALLED_AFTER_SECONDS so it is not lost.

  /// pending | processing | sent | retry | failed
  reminderState  String    @default("pending") @map("reminder_state")
  /// Delivery attempts made so far (incremented on claim).
  reminderAttempts Int     @default(0) @map("reminder_attempts")
  /// Earliest UTC instant the next attempt may be claimed (backoff). Null = now.
  reminderNextAttemptAt DateTime? @map("reminder_next_attempt_at")
  /// Set once Telegram has accepted the reminder. Null until then.
  reminderSentAt DateTime? @map("reminder_sent_at")
  /// Last transient/permanent failure reason (safe label only, never payloads).
  reminderFailedReason String? @map("reminder_failed_reason")

  user BotUser @relation(fields: [telegramUserId], references: [telegramUserId], onDelete: Cascade)

  drafts TaskDraft[]

  @@index([telegramUserId, status, remindAt], map: "tasks_user_status_remind_idx")
  /// Drives the due-reminder scan: only rows still awaiting delivery.
  @@index([reminderState, remindAt, reminderNextAttemptAt], map: "tasks_reminder_due_idx")
  /// Drives the stalled-claim reaper.
  @@index([reminderState, updatedAt], map: "tasks_reminder_stalled_idx")
  @@map("tasks")
}

/// In-progress conversation state (create/edit wizard). One per user: starting a
/// new flow replaces the old one, so an abandoned draft can never wedge the bot.
model TaskDraft {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  telegramUserId BigInt   @unique @map("telegram_user_id")
  /// awaiting_title | awaiting_time | awaiting_confirm | awaiting_custom_date | awaiting_edit_title
  step           String
  title          String?
  /// Set when the flow edits an existing task instead of creating one.
  taskId         String?  @db.Uuid @map("task_id")
  /// The wizard card being edited in place, so we update instead of spamming new messages.
  cardChatId     BigInt?  @map("card_chat_id")
  cardMessageId  Int?     @map("card_message_id")
  /// Pending remind_at (UTC) awaiting confirmation.
  remindAt       DateTime? @map("remind_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user BotUser @relation(fields: [telegramUserId], references: [telegramUserId], onDelete: Cascade)
  task Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_drafts")
}

model ProcessedUpdate {
  updateId    BigInt   @id @map("update_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_updates")
}
