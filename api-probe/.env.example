# --- Telegram Business API Probe: env template ---
# Copy to .env and fill in.  Never commit .env.

# Bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Random secret string. Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header; we verify it on every webhook.
# Allowed chars: A-Z a-z 0-9 _ -  (1..256 chars). Generate e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Public HTTPS URL of your tunnel (ngrok / cloudflared), no trailing slash.
# The webhook path /webhook is appended automatically.
# Example: https://abcd-1-2-3-4.ngrok-free.app
PUBLIC_URL=https://your-tunnel-host

# Local port the Express server listens on.
PORT=3000

# Telegram Bot API root (change only if using a self-hosted Bot API server).
TELEGRAM_API_ROOT=https://api.telegram.org
