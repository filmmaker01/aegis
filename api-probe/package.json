{
  "name": "telegram-business-api-probe",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 research tool: capture raw Telegram Business API updates (webhook logger). Not a product.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "delete-webhook": "tsx scripts/delete-webhook.ts",
    "webhook-info": "tsx scripts/get-webhook-info.ts",
    "get-me": "tsx scripts/get-me.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
